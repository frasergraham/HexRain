{
  "name": "hex-rain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:ios": "tsc && vite build --base=./ --outDir=dist --emptyOutDir",
    "ios:add": "cap add ios --packagemanager SPM",
    "ios:sync": "npm run build:ios && cap sync ios && node scripts/patch-cap-plugins.mjs",
    "ios:copy": "npm run build:ios && cap copy ios && node scripts/patch-cap-plugins.mjs",
    "ios:open": "cap open ios"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/matter-js": "^0.20.2",
    "jose": "^6.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "matter-js": "^0.20.0"
  }
}
